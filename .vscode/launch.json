{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Milk-V Duo",
      "type": "cppdbg",
      "request": "launch",
      "cwd": "${workspaceRoot}",
      "program": "Output/Baremetal_Milk-V_multicore_nosdk.elf",
      //"svdPath": "Code/Mcal/xxx.svd",
      "miDebuggerPath": "/opt/riscv-gcc/Xuantie-900-gcc-elf-newlib-i386-V3.3.0/bin/riscv64-unknown-elf-gdb",
      "miDebuggerServerAddress": "localhost:3333",
      "MIMode": "gdb",
      "stopAtEntry": true,
      "preLaunchTask": "Run DebugServer",
      "postDebugTask": "Stop DebugServer",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ],
      "postRemoteConnectCommands": [
        {
          "description": "GDB initialization file",
          "text": "source Debug/.gdbinit"
        }
      ]
    }
  ]
}